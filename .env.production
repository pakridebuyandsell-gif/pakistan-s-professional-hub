# Production environment for WorqGo frontend
# Copied into the image at build time (VITE_* vars are inlined at build).

NODE_ENV=production
HOST=0.0.0.0
PORT=3001
NITRO_HOST=0.0.0.0
NITRO_PORT=3001

# Backend API
VITE_API_URL=https://api.worqgo.com

# Firebase (publishable web keys — safe to expose)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
